# ─── DEMO MODE ──────────────────────────────────────────────────────────────
# Zet op "true" voor de publieke demo (geen echte API keys nodig)
NEXT_PUBLIC_DEMO_MODE=true

# ─── Verplicht in productie (niet nodig in demo mode) ────────────────────────
# DATABASE_URL=postgresql://...
# ADMIN_COOKIE_SECRET=minimaal-16-tekens-lang

# Admin PINs als JSON (format: {"PIN": {"naam":"Naam","rol":"owner","vestiging":"bb"}})
# In demo mode worden de PINs 1111 (owner) en 2222 (manager) gebruikt
# ADMIN_PINS_JSON={"0000":{"naam":"Owner","rol":"owner","vestiging":"bb"}}

# ─── Optioneel — alleen nodig in productie ───────────────────────────────────
# SumUp kassasysteem
# SUMUP_KEY_BB=...
# SUMUP_KEY_SL=...
# SUMUP_KEY_KL=...

# Zettle kassasysteem
# ZETTLE_TOKEN_BB=...
# ZETTLE_TOKEN_SL=...
# ZETTLE_TOKEN_KL=...

# ING banking (Open Banking API)
# ING_CLIENT_ID=...
# ING_CLIENT_SECRET=...

# Vercel KV (rate limiting + caching)
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...

# Claude AI (financieel adviseur + factuur-AI)
# ANTHROPIC_API_KEY=...

# Push notifications (web-push)
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...

# E-mail (Resend)
# RESEND_API_KEY=...
